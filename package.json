{
  "name": "tx-localist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed-cities": "node scripts/seed-cities.mjs",
    "db:seed-categories": "node scripts/seed-categories.mjs",
    "db:seed-plans": "node scripts/seed-plans.mjs",
    "db:seed-events": "node scripts/seed-event-data.mjs",
    "db:seed-admin": "node scripts/seed-admin.mjs",
    "db:seed-tags": "node scripts/seed-event-tags.mjs",
    "db:seed-test-users": "node scripts/seed-test-users.mjs",
    "db:seed-all": "npm run db:seed-cities && npm run db:seed-categories && npm run db:seed-plans && npm run db:seed-events",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@uploadthing/react": "^7.3.3",
    "dotenv": "^17.4.2",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^4.5.1",
    "uploadthing": "^7.7.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.7.0"
  }
}
