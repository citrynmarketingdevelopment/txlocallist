# =============================================================================
# TX Localist — environment variables
# Copy this file to `.env` and fill in values before running `npm run dev`.
# Do NOT commit `.env` (it is ignored in .gitignore).
# =============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"

# --- Database (Neon / Postgres) ---------------------------------------------
# Include `?sslmode=require` for Neon.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth --------------------------------------------------------------------
# Long random string used to sign session tokens.
SESSION_SECRET=""

# --- Billing (Stripe — added in Phase 6) ------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PK=""

# --- Email (Resend — added in Phase 5) --------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Texas Localist <hello@txlocalist.com>"

# --- Image uploads (UploadThing or Cloudinary — Phase 5) --------------------
UPLOADTHING_TOKEN=""
# CLOUDINARY_URL=""

# --- Maps --------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- AI search (optional, legacy /results demo) -----------------------------
NEXT_PUBLIC_GEMINI_API_KEY=""

# --- Observability (Phase 0 nice-to-have) -----------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
